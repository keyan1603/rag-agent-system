# RAG Agent Configuration

# Gemini API Key (required)
# Get your free API key from: https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here

# Logging level
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Vector database (for production RAG)
# PINECONE_API_KEY=your_pinecone_key
# PINECONE_INDEX_NAME=rag-agent

# Optional: Database connection (for storing conversations)
# DATABASE_URL=postgresql://user:password@localhost/rag_agent

# Optional: Monitoring
# SENTRY_DSN=https://your_sentry_dsn
